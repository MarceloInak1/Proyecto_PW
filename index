
<style>
  @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700&display=swap');

  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink: var(--color-text-primary);
    --muted: var(--color-text-secondary);
    --surface: var(--color-background-primary);
    --raised: var(--color-background-secondary);
    --border: var(--color-border-tertiary);
    --accent: #1D9E75;
    --accent-light: #E1F5EE;
    --accent-mid: #5DCAA5;
    --warm: #F0997B;
    --warm-light: #FAECE7;
    --amber: #EF9F27;
    --amber-light: #FAEEDA;
    --purple: #7F77DD;
    --purple-light: #EEEDFE;
  }

  body { font-family: 'Syne', sans-serif; background: transparent; overflow-x: hidden; }

  .app { display: flex; flex-direction: column; }

  /* NAV */
  .nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 2rem; border-bottom: 0.5px solid var(--border);
    background: var(--surface);
    position: sticky; top: 0; z-index: 100;
  }
  .nav-logo {
    font-family: 'Instrument Serif', serif; font-size: 22px; letter-spacing: -0.5px;
    color: var(--ink);
  }
  .nav-logo span { color: var(--accent); font-style: italic; }
  .nav-links { display: flex; gap: 1.5rem; align-items: center; }
  .nav-links a {
    font-size: 13px; color: var(--muted); text-decoration: none; letter-spacing: 0.02em;
    transition: color 0.2s;
    cursor: pointer;
  }
  .nav-links a:hover { color: var(--ink); }
  .btn-nav {
    background: var(--ink); color: var(--surface); border: none;
    padding: 6px 16px; border-radius: 100px; font-size: 13px;
    font-family: 'Syne', sans-serif; cursor: pointer; letter-spacing: 0.02em;
    transition: opacity 0.2s;
  }
  .btn-nav:hover { opacity: 0.75; }

  /* HERO */
  .hero {
    padding: 5rem 2rem 3rem;
    display: flex; flex-direction: column; align-items: center; text-align: center;
    position: relative; overflow: hidden;
  }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--accent-light); color: #0F6E56;
    font-size: 11px; letter-spacing: 0.08em; padding: 4px 12px;
    border-radius: 100px; margin-bottom: 1.5rem;
    font-family: 'DM Mono', monospace;
  }
  .hero-tag::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent); display: inline-block;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.7)} }

  .hero h1 {
    font-family: 'Instrument Serif', serif; font-size: 52px; line-height: 1.05;
    letter-spacing: -1.5px; color: var(--ink); max-width: 640px; margin-bottom: 1.25rem;
  }
  .hero h1 em { font-style: italic; color: var(--accent); }
  .hero p {
    font-size: 16px; color: var(--muted); max-width: 440px; line-height: 1.65;
    margin-bottom: 2.5rem; font-family: 'Syne', sans-serif; font-weight: 400;
  }

  /* QUICK DUMP */
  .quick-dump {
    width: 100%; max-width: 600px;
    display: flex; flex-direction: column; align-items: stretch; gap: 0;
    border: 1.5px solid var(--border); border-radius: 16px;
    background: var(--surface); overflow: hidden;
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--accent) 8%, transparent);
    transition: box-shadow 0.3s;
  }
  .quick-dump:focus-within {
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--accent) 18%, transparent);
    border-color: var(--accent-mid);
  }
  .dump-header {
    display: flex; align-items: center; gap: 8px; padding: 10px 14px;
    border-bottom: 0.5px solid var(--border);
    background: var(--raised);
  }
  .dump-header span {
    font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace;
    letter-spacing: 0.06em;
  }
  .dump-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); }
  .dump-textarea {
    border: none; outline: none; padding: 1rem 1.25rem;
    font-size: 15px; font-family: 'Syne', sans-serif; color: var(--ink);
    background: var(--surface); resize: none; width: 100%; height: 80px;
    line-height: 1.6;
  }
  .dump-textarea::placeholder { color: var(--muted); opacity: 0.6; }
  .dump-actions {
    display: flex; align-items: center; justify-content: space-between;
    padding: 8px 12px; border-top: 0.5px solid var(--border);
    background: var(--raised);
  }
  .dump-meta {
    font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace;
    display: flex; gap: 12px;
  }
  .btn-dump {
    background: var(--accent); color: white; border: none;
    padding: 7px 20px; border-radius: 100px; font-size: 13px;
    font-family: 'Syne', sans-serif; font-weight: 600; cursor: pointer;
    display: flex; align-items: center; gap: 6px;
    transition: background 0.2s, transform 0.1s;
  }
  .btn-dump:hover { background: #0F6E56; }
  .btn-dump:active { transform: scale(0.97); }
  .btn-dump .kbd { font-size: 10px; opacity: 0.7; font-family: 'DM Mono',monospace; }

  /* SECTIONS PREVIEW */
  .sections-strip {
    display: flex; gap: 0; padding: 0 0 0 2rem;
    border-top: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
    overflow-x: auto; scrollbar-width: none;
    margin-top: 0;
  }
  .sections-strip::-webkit-scrollbar { display: none; }
  .section-tab {
    display: flex; align-items: center; gap: 8px; padding: 0.85rem 1.5rem;
    font-size: 12px; letter-spacing: 0.05em; color: var(--muted); cursor: pointer;
    border-right: 0.5px solid var(--border); white-space: nowrap;
    transition: all 0.2s; user-select: none;
    border-bottom: 2px solid transparent;
  }
  .section-tab.active {
    color: var(--ink); border-bottom: 2px solid var(--accent);
    background: var(--raised);
  }
  .section-tab:hover:not(.active) { background: var(--raised); color: var(--ink); }
  .tab-icon { font-size: 16px; }

  /* MAIN PANELS */
  .panel { display: none; }
  .panel.active { display: block; }

  /* BRAINDUMP PANEL */
  .braindump-panel { padding: 1.5rem 2rem; }
  .bd-toolbar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1rem;
  }
  .bd-title {
    font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace;
    letter-spacing: 0.08em;
  }
  .bd-actions { display: flex; gap: 8px; }
  .btn-sm {
    border: 0.5px solid var(--border); background: var(--surface);
    color: var(--muted); padding: 4px 12px; border-radius: 100px;
    font-size: 11px; cursor: pointer; font-family: 'Syne', sans-serif;
    transition: all 0.15s;
  }
  .btn-sm:hover { color: var(--ink); border-color: var(--accent-mid); }

  .mural {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 12px;
    min-height: 280px;
    padding: 1rem;
    background: var(--raised);
    border-radius: 12px;
    border: 0.5px solid var(--border);
    position: relative;
  }
  .mural-empty {
    position: absolute; inset: 0; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 8px;
    color: var(--muted); font-size: 13px; pointer-events: none;
  }
  .mural-empty .empty-icon { font-size: 28px; opacity: 0.3; }

  .postit {
    border-radius: 2px; padding: 14px 14px 28px;
    font-size: 13px; line-height: 1.55; color: #2C2C2A;
    position: relative; cursor: pointer;
    transform: rotate(var(--r, 0deg));
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 2px 3px 0 rgba(0,0,0,0.08);
    animation: popin 0.3s cubic-bezier(0.175,0.885,0.32,1.275) both;
    word-break: break-word;
  }
  @keyframes popin { from{transform:scale(0.7) rotate(var(--r,0deg));opacity:0} to{transform:scale(1) rotate(var(--r,0deg));opacity:1} }
  .postit:hover {
    transform: scale(1.04) rotate(0deg);
    box-shadow: 4px 6px 0 rgba(0,0,0,0.13);
    z-index: 10;
  }
  .postit-meta {
    position: absolute; bottom: 8px; left: 14px; right: 14px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .postit-time {
    font-size: 10px; opacity: 0.5; font-family: 'DM Mono', monospace;
  }
  .postit-org {
    font-size: 10px; background: rgba(0,0,0,0.08); padding: 2px 7px;
    border-radius: 100px; opacity: 0.0; transition: opacity 0.2s;
  }
  .postit:hover .postit-org { opacity: 1; }

  .postit-colors {
    '--y': '#FAEEDA', '--g': '#EAF3DE', '--b': '#E6F1FB',
    '--p': '#EEEDFE', '--c': '#E1F5EE', '--k': '#FAECE7'
  }

  /* TASKS PANEL */
  .tasks-panel { padding: 1.5rem 2rem; }
  .tasks-filters {
    display: flex; gap: 8px; margin-bottom: 1rem; flex-wrap: wrap;
  }
  .filter-btn {
    border: 0.5px solid var(--border); background: var(--surface);
    color: var(--muted); padding: 5px 14px; border-radius: 100px;
    font-size: 12px; cursor: pointer; font-family: 'Syne',sans-serif;
    transition: all 0.15s;
  }
  .filter-btn.active {
    background: var(--ink); color: var(--surface); border-color: var(--ink);
  }
  .filter-btn:hover:not(.active) { border-color: var(--muted); color: var(--ink); }

  .tasks-list { display: flex; flex-direction: column; gap: 8px; }
  .task-card {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 16px; border-radius: 10px;
    border: 0.5px solid var(--border); background: var(--surface);
    transition: border-color 0.15s; cursor: pointer;
  }
  .task-card:hover { border-color: var(--accent-mid); }
  .task-check {
    width: 18px; height: 18px; border-radius: 50%;
    border: 1.5px solid var(--border); flex-shrink: 0;
    transition: all 0.2s; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
  }
  .task-check.done { background: var(--accent); border-color: var(--accent); }
  .task-check.done::after { content: '✓'; color: white; font-size: 10px; }
  .task-info { flex: 1; }
  .task-name { font-size: 14px; color: var(--ink); font-weight: 400; }
  .task-name.done { text-decoration: line-through; color: var(--muted); }
  .task-sub { font-size: 11px; color: var(--muted); margin-top: 2px; display: flex; gap: 10px; }
  .task-tag {
    font-size: 10px; padding: 2px 8px; border-radius: 100px;
    font-family: 'DM Mono', monospace; letter-spacing: 0.04em;
  }
  .tag-escuela { background: var(--purple-light); color: #3C3489; }
  .tag-trabajo { background: var(--amber-light); color: #633806; }
  .tag-personal { background: var(--accent-light); color: #085041; }

  /* PROGRESS PANEL */
  .progress-panel { padding: 1.5rem 2rem; }
  .habits-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px;
  }
  .habit-card {
    border: 0.5px solid var(--border); border-radius: 12px;
    background: var(--surface); padding: 1rem;
  }
  .habit-name { font-size: 13px; color: var(--ink); margin-bottom: 8px; font-weight: 600; }
  .habit-streak {
    font-family: 'Instrument Serif', serif; font-size: 28px; color: var(--accent);
    line-height: 1; margin-bottom: 4px;
  }
  .habit-label { font-size: 11px; color: var(--muted); margin-bottom: 10px; }
  .habit-dots { display: flex; gap: 4px; flex-wrap: wrap; }
  .h-dot {
    width: 14px; height: 14px; border-radius: 3px;
    background: var(--raised); border: 0.5px solid var(--border);
  }
  .h-dot.filled { background: var(--accent); border-color: var(--accent); }
  .h-dot.partial { background: var(--accent-mid); border-color: var(--accent-mid); opacity: 0.5; }

  /* MODAL */
  .modal-overlay {
    display: none; position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,0.45);
    align-items: center; justify-content: center;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: var(--surface); border-radius: 16px;
    border: 0.5px solid var(--border);
    padding: 1.5rem; width: 340px; max-width: 90vw;
  }
  .modal h3 {
    font-family: 'Instrument Serif', serif; font-size: 20px; margin-bottom: 1rem;
    color: var(--ink);
  }
  .modal-field { margin-bottom: 0.75rem; }
  .modal-field label { font-size: 11px; color: var(--muted); display: block; margin-bottom: 4px; letter-spacing: 0.05em; }
  .modal-field input, .modal-field select, .modal-field textarea {
    width: 100%; border: 0.5px solid var(--border); border-radius: 8px;
    padding: 7px 10px; font-size: 13px; background: var(--surface); color: var(--ink);
    font-family: 'Syne', sans-serif; outline: none;
    transition: border-color 0.2s;
  }
  .modal-field input:focus, .modal-field select:focus { border-color: var(--accent-mid); }
  .modal-actions { display: flex; gap: 8px; margin-top: 1rem; justify-content: flex-end; }
  .btn-cancel {
    border: 0.5px solid var(--border); background: transparent; color: var(--muted);
    padding: 7px 16px; border-radius: 100px; font-size: 12px; cursor: pointer;
    font-family: 'Syne', sans-serif;
  }
  .btn-confirm {
    background: var(--accent); color: white; border: none;
    padding: 7px 16px; border-radius: 100px; font-size: 12px; cursor: pointer;
    font-family: 'Syne', sans-serif; font-weight: 600;
  }
  .btn-confirm:hover { background: #0F6E56; }

  .fade-in { animation: fadeIn 0.25s ease both; }
  @keyframes fadeIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }
</style>

