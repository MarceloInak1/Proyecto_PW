<script>
const COLORS = ['#FAEEDA','#EAF3DE','#E6F1FB','#EEEDFE','#E1F5EE','#FAECE7'];
const ROTATIONS = [-2,-1.2,0,1,2,1.5,-1.5,0.5,-0.5];
let notes = [];
let selectedNoteId = null;
let noteCount = 0;

const input = document.getElementById('dump-input');
const mural = document.getElementById('mural');
const muralEmpty = document.getElementById('mural-empty');
const dumpCount = document.getElementById('dump-count');
const dumpTime = document.getElementById('dump-time');
const btnSend = document.getElementById('btn-send-dump');

function getTime() {
  const d = new Date();
  return d.toLocaleTimeString('es-MX', {hour:'2-digit', minute:'2-digit'});
}

function updateTime() {
  dumpTime.textContent = getTime();
}
setInterval(updateTime, 30000);
updateTime();

function sendDump() {
  const text = input.value.trim();
  if (!text) return;
  noteCount++;
  const id = noteCount;
  const color = COLORS[id % COLORS.length];
  const rot = ROTATIONS[id % ROTATIONS.length];
  const time = getTime();
  notes.push({id, text, color, rot, time});
  renderNote({id, text, color, rot, time});
  input.value = '';
  if (muralEmpty) muralEmpty.style.display = 'none';
  dumpCount.textContent = `${notes.length} idea${notes.length > 1 ? 's' : ''}`;
  switchPanel('braindump');
}

function renderNote({id, text, color, rot, time}) {
  const el = document.createElement('div');
  el.className = 'postit';
  el.style.cssText = `background:${color};--r:${rot}deg;`;
  el.dataset.id = id;
  el.innerHTML = `
    <span>${text}</span>
    <div class="postit-meta">
      <span class="postit-time">${time}</span>
      <span class="postit-org" onclick="openModal(${id}, event)">organizar →</span>
    </div>
  `;
  el.addEventListener('click', () => {
    openModal(id, {stopPropagation: ()=>{}});
  });
  mural.appendChild(el);
}

input.addEventListener('keydown', (e) => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendDump();
  }
});
btnSend.addEventListener('click', sendDump);

function switchPanel(name) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.section-tab').forEach(t => t.classList.remove('active'));
  document.getElementById(`panel-${name}`).classList.add('active');
  document.querySelector(`[data-panel="${name}"]`).classList.add('active');
}

function openModal(id, e) {
  e.stopPropagation && e.stopPropagation();
  selectedNoteId = id;
  const note = notes.find(n => n.id == id);
  if (note) {
    document.getElementById('modal-name').value = note.text.slice(0, 40);
    document.getElementById('modal-desc').value = '';
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('modal-date').value = today;
  }
  document.getElementById('modal-overlay').classList.add('open');
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
  selectedNoteId = null;
}

function confirmOrganize() {
  const name = document.getElementById('modal-name').value.trim() || 'Nueva tarea';
  const tag = document.getElementById('modal-tag').value;
  const date = document.getElementById('modal-date').value;
  const tagMap = {personal:'tag-personal',trabajo:'tag-trabajo',escuela:'tag-escuela',familia:'tag-personal'};
  const dateStr = date ? new Date(date).toLocaleDateString('es-MX',{weekday:'short',day:'numeric',month:'short'}) : 'Sin fecha';
  const list = document.getElementById('tasks-list');
  const card = document.createElement('div');
  card.className = 'task-card fade-in';
  card.innerHTML = `
    <div class="task-check" onclick="this.classList.toggle('done')"></div>
    <div class="task-info">
      <div class="task-name">${name}</div>
      <div class="task-sub">
        <span>${dateStr}</span>
        <span class="task-tag ${tagMap[tag]||'tag-personal'}">${tag}</span>
      </div>
    </div>
  `;
  list.prepend(card);
  if (selectedNoteId) {
    const noteEl = mural.querySelector(`[data-id="${selectedNoteId}"]`);
    if (noteEl) {
      noteEl.style.opacity = '0.35';
      noteEl.style.pointerEvents = 'none';
    }
    notes = notes.filter(n => n.id != selectedNoteId);
  }
  closeModal();
  switchPanel('tasks');
}

document.getElementById('modal-overlay').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  });
});

document.querySelectorAll('.task-check').forEach(check => {
  check.addEventListener('click', function(e) {
    e.stopPropagation();
    this.classList.toggle('done');
    const nameEl = this.parentElement.querySelector('.task-name');
    if (nameEl) nameEl.classList.toggle('done', this.classList.contains('done'));
  });
});

function buildDots(id, filled, partial, total) {
  const el = document.getElementById(id);
  if (!el) return;
  for (let i = 0; i < total; i++) {
    const d = document.createElement('div');
    d.className = 'h-dot' + (i < filled ? ' filled' : i < filled + partial ? ' partial' : '');
    el.appendChild(d);
  }
}
buildDots('dots-read', 12, 0, 21);
buildDots('dots-dump', 7, 2, 21);
buildDots('dots-tasks', 14, 2, 21);
</script>
